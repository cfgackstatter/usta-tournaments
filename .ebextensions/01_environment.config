# .ebextensions/01_environment.config
option_settings:
  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: "/var/app/current:/var/app/current/backend:$PYTHONPATH"
    APP_DATA_DIR: "/var/app/shared/data"
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx

files:
  "/opt/elasticbeanstalk/tasks/taillogs.d/app-logs.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/app-updates.log
      /var/log/uvicorn.log
      /var/log/gunicorn.log

commands:
  01_create_data_dir:
    command: "mkdir -p /var/app/shared/data && chown webapp:webapp /var/app/shared/data && chmod 755 /var/app/shared/data"
    ignoreErrors: true