# .ebextensions/04_post_deploy_update.config
# Trigger tournament update in background after deployment

container_commands:
  01_update_tournaments:
    command: |
      nohup bash -c '
        sleep 15
        cd /var/app/current
        source /var/app/venv/*/bin/activate
        export PYTHONPATH="/var/app/current:/var/app/current/backend:$PYTHONPATH"
        echo "===== Post-deployment update at $(date) =====" >> /var/log/app-updates.log
        python3 -m backend.main --update --max-pages 100 >> /var/log/app-updates.log 2>&1
        if [ $? -eq 0 ]; then
          echo "✓ Post-deployment update successful at $(date)" >> /var/log/app-updates.log
        else
          echo "✗ Post-deployment update failed at $(date)" >> /var/log/app-updates.log
        fi
      ' >> /var/log/app-updates.log 2>&1 </dev/null &
      exit 0
    leader_only: true
