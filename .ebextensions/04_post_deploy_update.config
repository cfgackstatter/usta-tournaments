# .ebextensions/04_post_deploy_update.config
# Run tournament update after deployment to ensure fresh data

container_commands:
  01_update_tournaments:
    command: |
      cd /var/app/current
      source /var/app/venv/*/bin/activate
      export PYTHONPATH="/var/app/current:/var/app/current/backend:$PYTHONPATH"
      
      echo "===== Running post-deployment tournament update at $(date) =====" >> /var/log/app-updates.log
      python3 -m backend.main --update --max-pages 100 >> /var/log/app-updates.log 2>&1
      
      UPDATE_EXIT_CODE=$?
      if [ $UPDATE_EXIT_CODE -eq 0 ]; then
        echo "✓ Post-deployment update successful at $(date)" >> /var/log/app-updates.log
      else
        echo "⚠ Post-deployment update had issues (exit code: $UPDATE_EXIT_CODE) at $(date)" >> /var/log/app-updates.log
        echo "Application will use existing data until next scheduled update" >> /var/log/app-updates.log
      fi
      echo "===== Post-deployment update completed at $(date) =====" >> /var/log/app-updates.log
      
      exit 0
    leader_only: true
