# .ebextensions/04_post_deploy_update.config
commands:
  00_install_chromium_deps:
    command: |
      dnf install -y \
        atk \
        gtk3 \
        libX11 \
        libXcomposite \
        libXcursor \
        libXdamage \
        libXext \
        libXi \
        libXrandr \
        libXScrnSaver \
        libXxf86vm \
        pango \
        alsa-lib \
        nss
    ignoreErrors: false

container_commands:
  01_install_playwright_browsers:
    command: |
      mkdir -p /ms-playwright && chmod 777 /ms-playwright
      export PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
      source /var/app/venv/*/bin/activate
      python3 -m playwright install chromium >> /var/log/app-updates.log 2>&1
    leader_only: true

  02_update_usta:
    command: |
      cd /var/app/current
      source /var/app/venv/*/bin/activate
      export PYTHONPATH="/var/app/current:/var/app/current/backend:$PYTHONPATH"
      echo "===== Post-deployment USTA update at $(date) =====" >> /var/log/app-updates.log
      python3 -m backend.main --update-usta --max-pages "${POSTDEPLOY_USTA_MAX_PAGES:-100}" >> /var/log/app-updates.log 2>&1
      if [ $? -eq 0 ]; then
        echo "OK USTA post-deployment update successful at $(date)" >> /var/log/app-updates.log
      else
        echo "FAIL USTA post-deployment update failed at $(date)" >> /var/log/app-updates.log
      fi
    leader_only: true

  03_update_itf:
    command: |
      cd /var/app/current
      source /var/app/venv/*/bin/activate
      export PYTHONPATH="/var/app/current:/var/app/current/backend:$PYTHONPATH"
      export PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
      echo "===== Post-deployment ITF update at $(date) =====" >> /var/log/app-updates.log
      python3 -m backend.main --update-itf --months-back 0 --months-ahead "${POSTDEPLOY_ITF_MONTHS_AHEAD:-3}" >> /var/log/app-updates.log 2>&1
      if [ $? -eq 0 ]; then
        echo "OK ITF post-deployment update successful at $(date)" >> /var/log/app-updates.log
      else
        echo "FAIL ITF post-deployment update failed at $(date)" >> /var/log/app-updates.log
      fi
    leader_only: true