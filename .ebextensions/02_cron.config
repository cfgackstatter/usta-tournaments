# .ebextensions/02_cron.config

commands:
  01_enable_crond:
    command: "systemctl enable crond.service"
    ignoreErrors: true
  02_start_crond:
    command: "systemctl start crond.service || service crond start"
    ignoreErrors: true
  03_verify_crond:
    command: "systemctl is-active crond.service || echo 'Warning: crond may not be running'"
    ignoreErrors: true
  04_remove_old_cron:
    command: "rm -f /etc/cron.d/app_update_job.bak"
    ignoreErrors: true
  05_reload_cron:
    command: "systemctl reload crond || service crond reload"
    ignoreErrors: true

files:
  "/etc/cron.d/app_update_job":
    mode: "000644"
    owner: root
    group: root
    content: |
      # USTA: daily at midnight UTC
      0 0 * * * root /usr/local/bin/update_usta.sh >> /var/log/app-updates.log 2>&1
      # ITF: weekly on Monday at 1am UTC
      0 1 * * 1 root /usr/local/bin/update_itf.sh >> /var/log/app-updates.log 2>&1

  "/usr/local/bin/update_usta.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      cd /var/app/current || exit 1
      source /var/app/venv/*/bin/activate
      export PYTHONPATH="/var/app/current:/var/app/current/backend:$PYTHONPATH"
      export APP_DATA_DIR="/var/app/shared/data"

      echo "===== USTA update started at $(date) =====" >> /var/log/app-updates.log
      python3 -m backend.main --update-usta --max-pages "${CRON_USTA_MAX_PAGES:-100}" >> /var/log/app-updates.log 2>&1
      if [ $? -eq 0 ]; then
        echo "OK USTA update successful at $(date)" >> /var/log/app-updates.log
      else
        echo "FAIL USTA update failed at $(date)" >> /var/log/app-updates.log
      fi
      echo "" >> /var/log/app-updates.log

  "/usr/local/bin/update_itf.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      cd /var/app/current || exit 1
      source /var/app/venv/*/bin/activate
      export PYTHONPATH="/var/app/current:/var/app/current/backend:$PYTHONPATH"
      export PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
      export APP_DATA_DIR="/var/app/shared/data"

      echo "===== ITF update started at $(date) =====" >> /var/log/app-updates.log
      python3 -m backend.main --update-itf --months-back 0 --months-ahead "${CRON_ITF_MONTHS_AHEAD:-12}" >> /var/log/app-updates.log 2>&1
      if [ $? -eq 0 ]; then
        echo "OK ITF update successful at $(date)" >> /var/log/app-updates.log
      else
        echo "FAIL ITF update failed at $(date)" >> /var/log/app-updates.log
      fi
      echo "" >> /var/log/app-updates.log
